        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# Загрузка данных\n",
        "df = pd.read_csv('/content/train.csv')\n",
        "\n",
        "# 1. Основная информация о датасете\n",
        "print(\"1. Основная информация о датасете:\")\n",
        "print(df.info())\n",
        "print(\"\\nОписательная статистика:\")\n",
        "print(df.describe())\n",
        "print(\"\\nКоличество пропусков в каждом столбце:\")\n",
        "print(df.isnull().sum())\n",
        "\n",
        "# 2. Процент выживаемости у каждого класса пассажиров\n",
        "print(\"\\n2. Процент выживаемости по классам:\")\n",
        "survival_by_class = df.groupby('Pclass')['Survived'].mean() * 100\n",
        "print(survival_by_class)\n",
        "\n",
        "# 3. Извлечение имен из столбца Name\n",
        "def extract_name(full_name):\n",
        "    # Ищем часть имени в кавычках или после точки\n",
        "    if '(' in full_name:\n",
        "        # Для случаев типа \"Braund, Mr. Owen Harris\" или \"Cumings, Mrs. John Bradley (Florence Briggs Thayer)\"\n",
        "        name_part = full_name.split('(')[-1].split(')')[0]\n",
        "        # Удаляем титулы в скобках\n",
        "        name_part = name_part.split(' ')[-1]\n",
        "    else:\n",
        "        # Для случаев без скобок\n",
        "        parts = full_name.split(' ')\n",
        "        name_part = parts[2] if len(parts) > 2 else parts[1]\n",
        "    return name_part\n",
        "\n",
        "df['FirstName'] = df['Name'].apply(extract_name)\n",
        "\n",
        "# 3. Самое популярное мужское и женское имя на корабле\n",
        "print(\"\\n3. Самое популярное мужское и женское имя:\")\n",
        "male_names = df[df['Sex'] == 'male']['FirstName'].value_counts()\n",
        "female_names = df[df['Sex'] == 'female']['FirstName'].value_counts()\n",
        "\n",
        "print(\"Самое популярное мужское имя:\", male_names.idxmax())\n",
        "print(\"Самое популярное женское имя:\", female_names.idxmax())\n",
        "\n",
        "# 4. Самое популярное имя в каждом классе\n",
        "print(\"\\n4. Самое популярное имя в каждом классе:\")\n",
        "for pclass in sorted(df['Pclass'].unique()):\n",
        "    print(f\"\\nКласс {pclass}:\")\n",
        "    class_df = df[df['Pclass'] == pclass]\n",
        "\n",
        "    male_names_class = class_df[class_df['Sex'] == 'male']['FirstName'].value_counts()\n",
        "    female_names_class = class_df[class_df['Sex'] == 'female']['FirstName'].value_counts()\n",
        "\n",
        "    if not male_names_class.empty:\n",
        "        print(f\"  Мужское имя: {male_names_class.idxmax()}\")\n",
        "    if not female_names_class.empty:\n",
        "        print(f\"  Женское имя: {female_names_class.idxmax()}\")\n",
        "\n",
        "# 5. Пассажиры старше 44 лет\n",
        "print(\"\\n5. Пассажиры старше 44 лет:\")\n",
        "print(df[df['Age'] > 44][['Name', 'Age', 'Sex', 'Pclass', 'Survived']].head())\n",
        "\n",
        "# 6. Пассажиры младше 44 лет и мужского пола\n",
        "print(\"\\n6. Пассажиры младше 44 лет и мужского пола:\")\n",
        "print(df[(df['Age'] < 44) & (df['Sex'] == 'male')][['Name', 'Age', 'Pclass', 'Survived']].head())\n",
        "\n",
        "# 7. Количество n-местных кабин (по количеству людей с одинаковым номером кабины)\n",
        "print(\"\\n7. Количество n-местных кабин:\")\n",
        "# Удаляем пропуски в номерах кабин\n",
        "cabin_counts = df[df['Cabin'].notna()]['Cabin'].value_counts()\n",
        "# Группируем по количеству людей в каюте\n",
        "n_people_in_cabin = cabin_counts.value_counts().sort_index()\n",
        "print(n_people_in_cabin)"
      ]
